# Copy this to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real values.

domain_name        = "mc.example.com"
hosted_zone_id     = ""          # Leave empty to create a new zone, or set your existing zone ID
aws_region         = "eu-west-1"
instance_type      = "t3.medium"
inactivity_minutes = 20
minecraft_version  = "latest"
spot_instance      = false
minecraft_memory_mb = 2048
availability_zone  = "eu-west-1a"   # Must match the AZ of your world data EBS volume
# key_name           = "my-key-pair"  # EC2 key pair name for SSH access; omit to disable

